# ============================================================
# WhatCode — пример конфигурации.
# Скопируй в `.env` (`cp .env.example .env`) и впиши свои значения.
# Файл `.env` в .gitignore и не должен коммититься.
# ============================================================

# ---------- Активный провайдер LLM ----------
# Допустимые значения: ollama | cerebras | deepseek | google_ai | anthropic | fireworks | opencode-go
LLM_PROVIDER=ollama

# ---------- Ollama (локально) ----------
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:4b
OLLAMA_TEMPERATURE=0.55
OLLAMA_NUM_CTX=2048
OLLAMA_KEEP_ALIVE=10m

# ---------- Cerebras (cloud) ----------
# Ключ: https://cloud.cerebras.ai/
CEREBRAS_API_KEY=
CEREBRAS_MODEL=gpt-oss-120b
CEREBRAS_TEMPERATURE=0.55
CEREBRAS_MAX_TOKENS=700
CEREBRAS_TIMEOUT_SECONDS=60

# ---------- DeepSeek / OpenRouter (опционально) ----------
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
# Для OpenRouter:
# DEEPSEEK_BASE_URL=https://openrouter.ai/api/v1

# ---------- Google AI Studio (опционально, нужен для --live-voice) ----------
GOOGLE_AI_API_KEY=
GOOGLE_AI_MODEL=gemma-3-27b-it
GOOGLE_AI_LIVE_MODEL=gemini-3.1-flash-live-preview
GOOGLE_AI_LIVE_API_VERSION=v1beta

# ---------- Anthropic / Claude (Rust) ----------
# LLM_PROVIDER=anthropic, чтобы использовать Claude.
# Ключ: https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Модели: claude-opus-4-8 | claude-sonnet-4-6 | claude-haiku-4-5
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_MAX_TOKENS=1024
ANTHROPIC_TIMEOUT_SECONDS=120
ANTHROPIC_RETRY_ATTEMPTS=3

# ---------- Fireworks AI (Rust) ----------
# LLM_PROVIDER=fireworks
# Ключ: https://fireworks.ai/
FIREWORKS_API_KEY=
FIREWORKS_MODEL=accounts/fireworks/models/kimi-k2p5-whatcode
FIREWORKS_TEMPERATURE=0.55
FIREWORKS_MAX_TOKENS=700
FIREWORKS_TIMEOUT_SECONDS=120

# ---------- OpenCode Go (Rust) ----------
# LLM_PROVIDER=opencode-go
# Подписка и ключ: https://opencode.ai/zen
# OpenAI-compatible endpoint: https://opencode.ai/zen/go/v1/chat/completions
OPENCODE_GO_API_KEY=
OPENCODE_GO_MODEL=kimi-k2.7-code
OPENCODE_GO_TEMPERATURE=0.55
OPENCODE_GO_MAX_TOKENS=700
OPENCODE_GO_TIMEOUT_SECONDS=120

# ---------- Озвучивание ответов / TTS (Rust) ----------
# Озвучивать ответы Герты автоматически. /say <текст> работает и при выключенном авто.
VOICE_ENABLED=false
# Провайдер: system | elevenlabs | google_cloud
VOICE_PROVIDER=system
# System-провайдер (macOS say / espeak-ng / PowerShell): переопределение команды/голоса
VOICE_TTS_COMMAND=
VOICE_NAME=
# ElevenLabs (облачный): https://elevenlabs.io/
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_multilingual_v2
# Google Cloud Text-to-Speech: https://cloud.google.com/text-to-speech
GOOGLE_TTS_API_KEY=
GOOGLE_TTS_VOICE=ru-RU-Standard-A
GOOGLE_TTS_LANGUAGE=ru-RU
# Microsoft Azure Speech (нужны ключ + регион): https://portal.azure.com/
AZURE_TTS_API_KEY=
AZURE_TTS_REGION=
AZURE_TTS_VOICE=ru-RU-SvetlanaNeural
# Alibaba Qwen / DashScope TTS: https://dashscope.console.aliyun.com/
QWEN_TTS_API_KEY=
QWEN_TTS_VOICE=Chelsie
QWEN_TTS_MODEL=qwen-tts
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/api/v1

# ---------- Распознавание речи / STT (Rust) ----------
# Провайдер: whisper_local (офлайн) | openai | deepgram | azure | google
# Работает по аудиофайлу: команда /transcribe <файл>. Живой микрофон — позже.
STT_PROVIDER=whisper_local
STT_LANGUAGE=ru
# Локальный Whisper (openai-whisper; ставится: uv pip install -U openai-whisper)
STT_WHISPER_COMMAND=
STT_WHISPER_MODEL=base
# Облачные STT: ключ/базовый URL/модель (OpenAI/Groq/Qwen — OpenAI-совместимый)
STT_API_KEY=
STT_BASE_URL=
STT_MODEL=
# Отдельные ключи тоже подхватываются: DEEPGRAM_API_KEY, AZURE_SPEECH_KEY,
# AZURE_SPEECH_REGION, OPENAI_API_KEY, GROQ_API_KEY, DASHSCOPE_API_KEY.

# ---------- Авто-recap (Rust) ----------
# Периодическая краткая сводка диалога (тумблер /recap on|off в TUI).
RECAP_ENABLED=false
RECAP_EVERY_TURNS=8

# ---------- Режим работы агента (Rust) ----------
# chat | plan | code | auto | full-auto. По умолчанию auto.
WHATCODE_MODE=auto

# ---------- Персона (Rust) ----------
# herta | anis | miku | default. По умолчанию herta.
# Цвет персоны используется в TUI как акцентный.
WHATCODE_PERSONA=herta

# ---------- Внешние агенты / Agent Context Protocol (Rust) ----------
# Делегирование задач другим CLI-агентам (claude -p, codex exec, gemini -p, …).
# Инструмент ask_external_agent помечен как опасный: в безопасных режимах
# требует подтверждения. Команды TUI: /agents и /delegate <id> <задача>.
WHATCODE_EXTERNAL_AGENTS=true
# Таймаут одного вызова внешнего агента (секунды).
WHATCODE_EXTERNAL_AGENT_TIMEOUT=300
# Агент по умолчанию, если id не указан (например, claude).
# WHATCODE_EXTERNAL_AGENT_DEFAULT=claude
# Пользовательские агенты: "id=программа арг1 {prompt};id2=прог2 …" (через ;).
# WHATCODE_EXTERNAL_AGENTS_CUSTOM=mycli=mytool run --json {prompt}

# ---------- Навыки агента (Rust) ----------
# Каталог с файлами навыков формата .skill/.whatcode (list_skills/use_skill).
WHATCODE_SKILLS_DIR=skills

# ---------- Нативный tool-loop (Rust) ----------
# Предел итераций вызова инструментов за один ход.
AGENT_TOOL_ITERATIONS=6

# ---------- STT / TTS / голос ----------
STT_PROVIDER=whisper
WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=cpu

EDGE_TTS_ENABLED=true

# ---------- RVC (оригинальный голос Герты, опционально) ----------
RVC_TTS_ENABLED=false
RVC_BACKEND=persistent
RVC_WARM_UP=true
RVC_BASE_TTS=silero
# Пути к Applio и модели на твоей машине:
RVC_APPLIO_ROOT=
RVC_APPLIO_PYTHON=
RVC_MODEL_PATH=
RVC_INDEX_PATH=
RVC_PITCH=0
RVC_F0_METHOD=rmvpe

# ---------- Короткая память диалога ----------
MEMORY_ENABLED=true
MAX_HISTORY_MESSAGES=8

# ---------- Долговременная память (факты между сессиями) ----------
LONG_MEMORY_ENABLED=true
LONG_MEMORY_PATH=data/long_memory.json
LONG_MEMORY_MAX_FACTS=200
# Auto-extract: каждые N реплик Герта делает доп LLM-запрос и сама извлекает
# стабильные факты. Можно отключить, чтоб экономить вызовы.
LONG_MEMORY_AUTO_EXTRACT=true
LONG_MEMORY_AUTO_EXTRACT_EVERY_TURNS=6

# ---------- Wake word ----------
# В режиме --voice Герта отвечает только когда слышит своё имя.
# В течение WAKEWORD_FOLLOW_UP_SECONDS после ответа можно говорить без имени.
WAKEWORD_ENABLED=true
# Режимы: text (только пост-STT матчинг) | porcupine | both
WAKEWORD_MODE=text
WAKEWORD_PHRASES=герта,герто,великая герта,эй герта,слушай герта,herta,hertha
WAKEWORD_FOLLOW_UP_SECONDS=60
# Заполняй только если WAKEWORD_MODE=porcupine или both:
# Ключ: https://console.picovoice.ai/
# .ppn для русского "Герта": Picovoice Console → Wake Words → Custom
PORCUPINE_ACCESS_KEY=
PORCUPINE_KEYWORD_PATHS=
PORCUPINE_SENSITIVITY=0.5

# ---------- Web search (Tavily) ----------
# Триггеры: "найди в интернете X", "погугли X", "новости про X",
# "какая погода в X", "что такое X", "кто такой X", "когда выходит X".
# Ключ: https://tavily.com/ (1000 запросов/мес бесплатно).
WEB_SEARCH_ENABLED=false
WEB_SEARCH_PROVIDER=tavily
TAVILY_API_KEY=
WEB_SEARCH_MAX_RESULTS=5
WEB_SEARCH_TIMEOUT_SECONDS=15
WEB_SEARCH_DEPTH=basic
# Если true — Герта делает доп LLM-вызов и пересказывает результаты своим голосом.
# Если false — зачитывает сырой ответ Tavily (быстрее, но "Герта" исчезает).
WEB_SEARCH_FOLLOWUP_IN_CHARACTER=true

# ---------- Code tools (mypy + ruff) ----------
# Голосовые команды: "проверь типы в X", "линтуй X".
# Самопроверка: после каждого ответа с кодом ≥ N строк прогоняет mypy+ruff
# и просит Герту переписать с учётом замечаний. Стоит +1 LLM-вызов.
CODE_TOOLS_ENABLED=false
CODE_TOOLS_PROJECT_ROOT=.
CODE_TOOLS_TIMEOUT_SECONDS=30
CODE_TOOLS_SELF_CHECK=false
CODE_TOOLS_SELF_CHECK_MAX_SNIPPETS=2
CODE_TOOLS_SELF_CHECK_MIN_LINES=3

# ---------- Контекстное окно и автосжатие (Rust) ----------
# Полный бюджет токенов модели. При достижении порога Герта сама сжимает
# середину истории в сводку, сохраняя персону и последние реплики.
CONTEXT_MAX_TOKENS=8192
# Доля бюджета (0.0..1.0), при которой запускается автосжатие.
CONTEXT_COMPACTION_THRESHOLD=0.8
# Сколько последних реплик сохранять дословно при сжатии.
CONTEXT_KEEP_RECENT_MESSAGES=6

# ---------- Саб-агенты / марионетки (Rust) ----------
AGENT_ENABLED=true
# Максимум одновременно работающих саб-агентов.
AGENT_MAX_CONCURRENT=4
# Таймаут на одного саб-агента, секунды.
AGENT_TIMEOUT_SECONDS=180

# ---------- Системные действия (открыть браузер/VS Code, создать .txt) ----------
SYSTEM_ACTIONS_ENABLED=false
SYSTEM_ACTIONS_DOCUMENT_DIR=desktop
SYSTEM_ACTIONS_REGISTRY_PATH=data/system_actions_registry.json
SYSTEM_ACTIONS_BROWSER_HOME_URL=https://www.google.com
SYSTEM_ACTIONS_VSCODE_COMMAND=code
SYSTEM_ACTIONS_VSCODE_OPEN_WORKSPACE=true
