# ============================================================
# The Herta Voice Assistant — пример конфигурации.
# Скопируй в `.env` (`cp .env.example .env`) и впиши свои значения.
# Файл `.env` в .gitignore и не должен коммититься.
# ============================================================

# ---------- Активный провайдер LLM ----------
# Допустимые значения: ollama | cerebras | deepseek | google_ai
LLM_PROVIDER=ollama

# ---------- Ollama (локально) ----------
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:4b
OLLAMA_TEMPERATURE=0.55
OLLAMA_NUM_CTX=2048
OLLAMA_KEEP_ALIVE=10m

# ---------- Cerebras (cloud) ----------
# Ключ: https://cloud.cerebras.ai/
CEREBRAS_API_KEY=
CEREBRAS_MODEL=gpt-oss-120b
CEREBRAS_TEMPERATURE=0.55
CEREBRAS_MAX_TOKENS=700
CEREBRAS_TIMEOUT_SECONDS=60

# ---------- DeepSeek / OpenRouter (опционально) ----------
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
# Для OpenRouter:
# DEEPSEEK_BASE_URL=https://openrouter.ai/api/v1

# ---------- Google AI Studio (опционально, нужен для --live-voice) ----------
GOOGLE_AI_API_KEY=
GOOGLE_AI_MODEL=gemma-3-27b-it
GOOGLE_AI_LIVE_MODEL=gemini-3.1-flash-live-preview
GOOGLE_AI_LIVE_API_VERSION=v1beta

# ---------- STT / TTS / голос ----------
STT_PROVIDER=whisper
WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=cpu

EDGE_TTS_ENABLED=true

# ---------- RVC (оригинальный голос Герты, опционально) ----------
RVC_TTS_ENABLED=false
RVC_BACKEND=persistent
RVC_WARM_UP=true
RVC_BASE_TTS=silero
# Пути к Applio и модели на твоей машине:
RVC_APPLIO_ROOT=
RVC_APPLIO_PYTHON=
RVC_MODEL_PATH=
RVC_INDEX_PATH=
RVC_PITCH=0
RVC_F0_METHOD=rmvpe

# ---------- Короткая память диалога ----------
MEMORY_ENABLED=true
MAX_HISTORY_MESSAGES=8

# ---------- Долговременная память (факты между сессиями) ----------
LONG_MEMORY_ENABLED=true
LONG_MEMORY_PATH=data/long_memory.json
LONG_MEMORY_MAX_FACTS=200
# Auto-extract: каждые N реплик Герта делает доп LLM-запрос и сама извлекает
# стабильные факты. Можно отключить, чтоб экономить вызовы.
LONG_MEMORY_AUTO_EXTRACT=true
LONG_MEMORY_AUTO_EXTRACT_EVERY_TURNS=6

# ---------- Wake word ----------
# В режиме --voice Герта отвечает только когда слышит своё имя.
# В течение WAKEWORD_FOLLOW_UP_SECONDS после ответа можно говорить без имени.
WAKEWORD_ENABLED=true
# Режимы: text (только пост-STT матчинг) | porcupine | both
WAKEWORD_MODE=text
WAKEWORD_PHRASES=герта,герто,великая герта,эй герта,слушай герта,herta,hertha
WAKEWORD_FOLLOW_UP_SECONDS=60
# Заполняй только если WAKEWORD_MODE=porcupine или both:
# Ключ: https://console.picovoice.ai/
# .ppn для русского "Герта": Picovoice Console → Wake Words → Custom
PORCUPINE_ACCESS_KEY=
PORCUPINE_KEYWORD_PATHS=
PORCUPINE_SENSITIVITY=0.5

# ---------- Web search (Tavily) ----------
# Триггеры: "найди в интернете X", "погугли X", "новости про X",
# "какая погода в X", "что такое X", "кто такой X", "когда выходит X".
# Ключ: https://tavily.com/ (1000 запросов/мес бесплатно).
WEB_SEARCH_ENABLED=false
WEB_SEARCH_PROVIDER=tavily
TAVILY_API_KEY=
WEB_SEARCH_MAX_RESULTS=5
WEB_SEARCH_TIMEOUT_SECONDS=15
WEB_SEARCH_DEPTH=basic
# Если true — Герта делает доп LLM-вызов и пересказывает результаты своим голосом.
# Если false — зачитывает сырой ответ Tavily (быстрее, но "Герта" исчезает).
WEB_SEARCH_FOLLOWUP_IN_CHARACTER=true

# ---------- Code tools (mypy + ruff) ----------
# Голосовые команды: "проверь типы в X", "линтуй X".
# Самопроверка: после каждого ответа с кодом ≥ N строк прогоняет mypy+ruff
# и просит Герту переписать с учётом замечаний. Стоит +1 LLM-вызов.
CODE_TOOLS_ENABLED=false
CODE_TOOLS_PROJECT_ROOT=.
CODE_TOOLS_TIMEOUT_SECONDS=30
CODE_TOOLS_SELF_CHECK=false
CODE_TOOLS_SELF_CHECK_MAX_SNIPPETS=2
CODE_TOOLS_SELF_CHECK_MIN_LINES=3

# ---------- Контекстное окно и автосжатие (Rust) ----------
# Полный бюджет токенов модели. При достижении порога Герта сама сжимает
# середину истории в сводку, сохраняя персону и последние реплики.
CONTEXT_MAX_TOKENS=8192
# Доля бюджета (0.0..1.0), при которой запускается автосжатие.
CONTEXT_COMPACTION_THRESHOLD=0.8
# Сколько последних реплик сохранять дословно при сжатии.
CONTEXT_KEEP_RECENT_MESSAGES=6

# ---------- Саб-агенты / марионетки (Rust) ----------
AGENT_ENABLED=true
# Максимум одновременно работающих саб-агентов.
AGENT_MAX_CONCURRENT=4
# Таймаут на одного саб-агента, секунды.
AGENT_TIMEOUT_SECONDS=180

# ---------- Системные действия (открыть браузер/VS Code, создать .txt) ----------
SYSTEM_ACTIONS_ENABLED=false
SYSTEM_ACTIONS_DOCUMENT_DIR=desktop
SYSTEM_ACTIONS_REGISTRY_PATH=data/system_actions_registry.json
SYSTEM_ACTIONS_BROWSER_HOME_URL=https://www.google.com
SYSTEM_ACTIONS_VSCODE_COMMAND=code
SYSTEM_ACTIONS_VSCODE_OPEN_WORKSPACE=true
